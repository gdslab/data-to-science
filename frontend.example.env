# API access token for Mapbox account
VITE_MAPBOX_ACCESS_TOKEN=
VITE_MAPTILER_API_KEY=
VITE_STAC_ENABLED=

# BreedBase OAuth hosts as JSON: {"hostname": {"authorizeUrl": "https://..."}}
# Leave empty to disable BreedBase OAuth
VITE_BREEDBASE_OAUTH_HOSTS=

# Cloudflare Turnstile (optional) - Leave empty to disable
VITE_TURNSTILE_SITE_KEY=

# STAC Browser URL (optional) - Leave empty to disable "Open in STAC Browser" links
VITE_STAC_BROWSER_URL=